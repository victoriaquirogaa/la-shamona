# --- GENERAL ---
.DS_Store
Thumbs.db

# --- PYTHON (Backend) ---
# Archivos compilados y cache
__pycache__/
*.py[cod]
*$py.class

# Entornos virtuales (donde se instalan las librerías)
venv/
env/
.env

# --- JAVASCRIPT / TYPESCRIPT (Frontend) ---
